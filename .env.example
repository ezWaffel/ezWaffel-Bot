# ============================================================================
#  ezWaffel Bot – Environment Variables
#  Copy to ".env" and fill in. NEVER commit the filled-in file.
# ============================================================================

# --- Discord (from https://discord.com/developers/applications) -------------
# Bot tab -> Token (Reset Token to reveal). This is a SECRET.
DISCORD_TOKEN=
# Your application's "Application ID" (General Information tab).
DISCORD_CLIENT_ID=
# The Discord server (guild) the bot operates in. Enable Developer Mode in
# Discord, right-click the server -> "Copy Server ID".
DISCORD_GUILD_ID=

# --- Internal API (must match the website) ----------------------------------
# Same shared secret as the website's BOT_API_SECRET.
BOT_API_SECRET=
# Port the internal API listens on. Website forwards here. Keep 4000.
PORT=4000

# --- Tickets (optional but recommended) -------------------------------------
# Category under which ticket channels are created (right-click a category ->
# Copy ID). Leave empty to create channels at the server root.
TICKET_CATEGORY_ID=
# Role that should see/manage all tickets (e.g. your staff role).
STAFF_ROLE_ID=
# Channel where ticket transcripts are posted on close. Leave empty to skip.
LOG_CHANNEL_ID=
